# Browser → Next (same origin). Waitlist hits POST /api/v1/waitlist on this app.
NEXT_PUBLIC_API_BASE_URL=/api/v1

# Server-only: proxy target (split so version can change without changing hostname)
# Local Go API:
INTERNAL_API_ORIGIN=http://localhost:3001
INTERNAL_API_PREFIX=/api/v1

# Vercel Production example:
# INTERNAL_API_ORIGIN=https://api.basktre.in
# INTERNAL_API_PREFIX=/api/v1

# Vercel Preview (dev branch) example:
# INTERNAL_API_ORIGIN=https://api.dev.basktre.in
# INTERNAL_API_PREFIX=/api/v1

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development

# Google OAuth (get from Google Cloud Console → APIs & Services → Credentials)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
