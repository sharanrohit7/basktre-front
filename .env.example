# Client → Next (same origin). Route handler proxies to INTERNAL_API_BASE_URL.
NEXT_PUBLIC_API_BASE_URL=/api/v1
# Server-only: real backend base (no trailing slash after /v1)
INTERNAL_API_BASE_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development
